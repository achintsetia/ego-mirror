rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Conversations — keyed by user email, subcollection sessions keyed by DD-MM-YYYY
    // Written only by Cloud Functions (Admin SDK); readable only by the owner
    match /conversations/{email} {
      allow read: if isAuthenticated() && request.auth.token.email == email;
      allow write: if false;

      match /sessions/{dateKey} {
        allow read: if isAuthenticated() && request.auth.token.email == email;
        allow write: if false;
      }
    }

    // User profiles — first-login onboarding tracking
    match /user_profiles/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.uid == request.auth.uid;
      allow update: if isOwner(userId);
      allow delete: if false;
    }

    // Productivity entries — written only by Cloud Functions (Admin SDK) on session create
    match /productivity/{email} {
      allow read: if isAuthenticated() && request.auth.token.email == email;
      allow write: if false;

      match /entries/{dateKey} {
        allow read: if isAuthenticated() && request.auth.token.email == email;
        allow write: if false;
      }
    }

    // Goals — accumulated by Cloud Functions on each session; readable by the owner
    match /goals/{email} {
      allow read: if isAuthenticated() && request.auth.token.email == email;
      allow write: if false;
    }

    // Good habits — accumulated by Cloud Functions on each session; readable by the owner
    match /goodhabits/{email} {
      allow read: if isAuthenticated() && request.auth.token.email == email;
      allow write: if false;
    }

    // Bad habits — accumulated by Cloud Functions on each session; readable by the owner
    match /badhabits/{email} {
      allow read: if isAuthenticated() && request.auth.token.email == email;
      allow write: if false;
    }

    // Default deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

